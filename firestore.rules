rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net: default-deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to settings documents ('content' and 'inquiries')
    // because the backend server interacts with Firestore.
    match /settings/{document} {
      allow read, write: if true;
    }
  }
}
